# --- Auth (NextAuth v5) ---
AUTH_SECRET=              # openssl rand -base64 32
AUTH_GOOGLE_ID=           # Google Cloud OAuth client ID
AUTH_GOOGLE_SECRET=       # Google Cloud OAuth client secret

# --- Fly.io provisioning ---
FLY_API_TOKEN=            # fly auth token (org-scoped deploy token recommended)
FLY_ORG_SLUG=personal     # org under which user apps are created
FLY_DEFAULT_REGION=iad    # default Fly region for provisioned machines

# --- OpenClaw instance ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_ANTHROPIC_API_KEY=  # optional: baked into each provisioned machine
