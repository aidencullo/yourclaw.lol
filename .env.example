ANTHROPIC_API_KEY=sk-ant-...
AUTH_SECRET=              # openssl rand -base64 32
AUTH_GOOGLE_ID=           # from Google Cloud Console
AUTH_GOOGLE_SECRET=       # from Google Cloud Console

# Fly.io provisioning
FLY_API_TOKEN=            # fly tokens create deploy -a your-app
FLY_APP_NAME=             # your Fly.io app name
FLY_MACHINE_IMAGE=        # Docker image to run (e.g. ghcr.io/openclaw/openclaw:latest)
FLY_DEFAULT_REGION=iad    # Fly.io region (iad = Virginia)
